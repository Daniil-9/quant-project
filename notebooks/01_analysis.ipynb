# импорт библиотек
import pandas as pd
import matplotlib.pyplot as plt

# загрузка данных
data = pd.read_csv('../data/BTC.csv')

# первые 5 строк
data.head()

# расчет доходности
data['returns'] = data['Close'].pct_change()

# среднее и стандартное отклонение
mean_ret = data['returns'].mean()
std_ret = data['returns'].std()

print("Средняя доходность:", mean_ret)
print("Стандартное отклонение:", std_ret)

# график цены
data['Close'].plot(title='BTC Price')
plt.show()
